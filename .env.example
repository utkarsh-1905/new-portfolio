# ── Blog APIs ─────────────────────────────────────────────────
# Dev.to API key — https://dev.to/settings/extensions
VITE_DEVTO=

# ── Spotify (refresh-token flow) ──────────────────────────────
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Add http://127.0.0.1:8888/callback as a Redirect URI
# 3. Run the one-time auth script to get your refresh token:
#    node scripts/spotify-auth.js
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# ── Removed / no longer needed ────────────────────────────────
# VITE_GITHUB_KEY   — GitHub tab was removed
# VITE_SPOTIFY_OAUTH — replaced by refresh-token flow above
